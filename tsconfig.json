{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "NodeNext",
    "target": "esnext",
    "types": [],
    "strict": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames":true,
    "typeRoots": ["./node_modules/@types","./src/types"]
    
  },
    "include":["src/**/*"],
    "exclude":["node_modules","prisma"],
}
